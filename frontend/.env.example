# LLM provider — "mistral" (default, EU-hosted) or "openai" (rollback)
LLM_PROVIDER=mistral

# Mistral La Plateforme API key (https://console.mistral.ai)
MISTRAL_API_KEY=

# OpenAI API key (kept for rollback; remove after SP-1 ships)
OPENAI_API_KEY=

# FastAPI backend URL (for upload and PDF export)
NEXT_PUBLIC_API_URL=http://localhost:8001

# Development-only pipeline diagnostic logger. When set to "1" (and
# NODE_ENV is not "production"), the analysis pipeline emits per-pass
# metric lines prefixed `[redline-debug]` to stdout. Never enable in
# production — see `src/lib/llm/debug-log.ts`.
# REDLINE_DEBUG_PIPELINE=1

# Pass 2 retry-on-short-array. Default: enabled. If a Pass 2 batch call
# returns fewer than half the expected analyzed clauses, the pipeline
# reissues the call once. Worst-case latency/cost is 2x on a collapsed
# first attempt. Set to "false" to disable during a provider incident.
# PASS2_RETRY_ENABLED=false
