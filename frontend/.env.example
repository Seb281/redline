# Mistral La Plateforme API key (https://console.mistral.ai)
# Mistral Small (Paris, EU) is the sole LLM provider.
MISTRAL_API_KEY=

# FastAPI backend URL (for upload and PDF export)
NEXT_PUBLIC_API_URL=http://localhost:8001

# Development-only pipeline diagnostic logger. When set to "1" (and
# NODE_ENV is not "production"), the analysis pipeline emits per-pass
# metric lines prefixed `[redline-debug]` to stdout. Never enable in
# production — see `src/lib/llm/debug-log.ts`.
# REDLINE_DEBUG_PIPELINE=1

# Pass 2 retry-on-short-array. Default: enabled. If a Pass 2 batch call
# returns fewer than half the expected analyzed clauses, the pipeline
# reissues the call once. Worst-case latency/cost is 2x on a collapsed
# first attempt. Set to "false" to disable during a provider incident.
# PASS2_RETRY_ENABLED=false

# DeepL API key — used only by the SP-7 seed script
# (scripts/deepl-seed.mjs) to generate non-EN UI catalogs from
# messages/en.json. Not read at runtime. Get a free key at
# https://www.deepl.com/pro-api — DeepL is EU-based (Cologne, DE).
# DEEPL_API_KEY=

# SP-7 Layer B' — ops rollback switch for localized LLM analysis.
# When set to a routing locale (e.g. "en"), every pipeline request
# resolves to that locale regardless of what the client sent, forcing
# the analyzer back to a single prompt language without a code change.
# Leave unset to honor the client's UI locale (the default behavior).
# See src/lib/analysis-locale.ts and docs/sp-roadmap-layer-b-prime.md.
# ANALYSIS_LOCALE_OVERRIDE=en

# SP-10 Arc 2 Task 2.3 — Jina Rerank API key (https://jina.ai — Berlin, EU).
# When set, the chat-context retriever reorders the top-20 fused
# candidates with Jina's cross-encoder (jina-reranker-v2-base-multilingual).
# Leave unset to skip reranking and serve chat context from the hybrid
# BM25 + cosine + graph widening stack alone (fail-soft by construction).
# JINA_API_KEY=
